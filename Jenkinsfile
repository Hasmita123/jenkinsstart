pipeline{
    agent any
    stages{
        stage('greetings'){
	    steps{
	        echo "Greetings from jenkins"
	    }
	}
	stage('build'){
	    steps{
	        echo "building.....!"
	    }
	}
	stage('test'){
	    steps{
	        echo "testing....!"
	    }
	}
	stage('deploy'){
	    steps{
	        echo "deploying....!"
	    }
	}
    }
}

